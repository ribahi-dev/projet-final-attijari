# =============================================================================
# backend/.env.example — configuration de l'API FastAPI.
#
# Usage : copier en `backend/.env` (non versionné) et adapter les valeurs.
# Ces variables sont chargées par pydantic-settings (app/core/config.py),
# qui les VALIDE au démarrage : une variable manquante ou mal typée fait
# échouer l'application immédiatement, au lieu de planter en pleine démo.
# =============================================================================
APP_NAME="NovaBank API"
APP_ENV=development

# Clé de signature des JWT. En production : longue, aléatoire, secrète.
# Générer la vôtre :  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=60

# URL SQLAlchemy : dialecte+driver://utilisateur:motdepasse@hôte:port/base
# Le driver est psycopg (version 3) — moderne, rapide, compatible async.
# Port 5433 : celui publié par docker-compose (5432 est souvent occupé
# par une installation PostgreSQL native sur les machines de dev).
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5433/novabank
